# AppyPie/AI ML API Key (get from https://aimlapi.com)
AIMLAPI_KEY=

# Optional
# AIMLAPI_BASE_URL=https://api.aimlapi.com
# IMAGEN_MODEL=google/imagen-4.0-generate-001

# Telegram bot token (optional)
# TELEGRAM_BOT_TOKEN=

# Comma-separated list of allowed CORS origins.
# In production, set this to your frontend domain in the Cloud Run environment variables.
# Example: CORS_ORIGINS=https://your-app.vercel.app
# For local dev, copy this file to .env and set your local origins:
CORS_ORIGINS=http://localhost:5173,http://localhost:8001,http://localhost:3000,http://127.0.0.1:5173,http://127.0.0.1:8001

# Output directory for generated images (defaults to ./generated)
# In production (Cloud Run), this is set to /app/output via the Dockerfile
# OUTPUT_DIR=/app/output
