# OpenRouter API key — get from https://openrouter.ai
OPENROUTER_API_KEY=

# Model to use via OpenRouter (default: openai/gpt-4o)
# OPENROUTER_MODEL=openai/gpt-4o

# Comma-separated allowed CORS origins.
# In production, set this in Cloud Run env vars — do not hardcode here.
# Example: CORS_ORIGINS=https://your-app.vercel.app
# For local dev, copy this file to .env:
CORS_ORIGINS=http://localhost:5173,http://localhost:8001,http://localhost:3000,http://127.0.0.1:5173,http://127.0.0.1:8001

# Telegram bot token (optional)
# TELEGRAM_BOT_TOKEN=

# Rate limiting — Upstash Redis (optional, disabled if not set). Shared engine:
# limits come from the central control sheet at runtime, with the values below as
# fallbacks. See DOCS/shared/rate-limit/central-config.md
# UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=AXxx...
# RATE_LIMIT_GENERATE_MAX=5         # max image generations per IP per window
# RATE_LIMIT_WINDOW_SECONDS=432000  # 5 days
